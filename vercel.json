{
  "version": 2,
  "builds": [
    { "src": "api/chat.js",   "use": "@vercel/node" },
    { "src": "api/upload.js", "use": "@vercel/node" },
    { "src": "api/admin.js",  "use": "@vercel/node" },
    { "src": "public/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat",   "dest": "/api/chat.js"   },
    { "src": "/api/upload", "dest": "/api/upload.js" },
    { "src": "/api/admin",  "dest": "/api/admin.js"  },
    { "src": "/(.*)",       "dest": "/public/$1"     }
  ]
}
